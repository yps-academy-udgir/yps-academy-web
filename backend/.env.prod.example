# Production Environment
PORT=4026
NODE_ENV=production

# MongoDB auth credentials (Docker Compose only)
# For Atlas deployments, set MONGODB_URI directly and leave these blank.
MONGO_ROOT_USERNAME=yps_admin
MONGO_ROOT_PASSWORD=change_me_in_production

# Database connection string
# Docker Compose:  mongodb://yps_admin:change_me_in_production@mongo:27017/yps-academy-prod?authSource=admin
# MongoDB Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/yps-academy-prod?retryWrites=true&w=majority
MONGODB_URI=mongodb://yps_admin:change_me_in_production@mongo:27017/yps-academy-prod?authSource=admin

# Frontend URL (CORS)
FRONTEND_URL=https://yps-academy.com
